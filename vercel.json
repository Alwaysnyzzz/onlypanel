{
  "rewrites": [
    { "source": "/",                       "destination": "/index.html" },
    { "source": "/home",                   "destination": "/index.html" },
    { "source": "/login",                  "destination": "/login.html" },
    { "source": "/register",               "destination": "/register.html" },
    { "source": "/product",                "destination": "/product.html" },
    { "source": "/product/panelptero",     "destination": "/panelptero.html" },
    { "source": "/contact",                "destination": "/contact.html" },
    { "source": "/isisaldo",               "destination": "/isisaldo.html" },
    { "source": "/pay",                    "destination": "/pay.html" },
    { "source": "/struk",                  "destination": "/struk.html" },
    { "source": "/struk/panel",            "destination": "/strukprodukpanel.html" },
    { "source": "/profile",                "destination": "/profile.html" },
    { "source": "/crop",                   "destination": "/crop.html" },
    { "source": "/create/userpanel",       "destination": "/create-userpanel.html" },
    { "source": "/detail/panel",           "destination": "/detail-panel.html" },
    { "source": "/api/(.*)",               "destination": "/api/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron/suspend-check",
      "schedule": "0 0 * * *"
    }
  ]
}
